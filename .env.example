# ZhiYan local development environment
#
# Copy this file to `.env` at the repository root for the backend. The frontend
# defaults to http://localhost:8000, but you can also export NEXT_PUBLIC_API_URL
# before running `pnpm dev` from `frontend/`.

# Frontend <-> backend
NEXT_PUBLIC_API_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://[::1]:3000"]
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$

# Model routing
DEFAULT_MODEL=openai:gpt-4o-mini
STRONG_MODEL=openai:gpt-4o
VISION_MODEL=openai:gpt-4o-mini
FAST_MODEL=

# Provider credentials. Leave unused providers empty.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Generation limits and timeouts
MAX_UPLOAD_SIZE_MB=50
MAX_SLIDE_PAGES=50
MAX_DOCUMENT_TOKENS=100000
GENERATE_TIMEOUT_SECONDS=300
JOB_TIMEOUT_SECONDS=1800
OUTLINE_TIMEOUT_SECONDS=90
LAYOUT_TIMEOUT_SECONDS=45
PER_SLIDE_TIMEOUT_SECONDS=75
VERIFY_TIMEOUT_SECONDS=90
MAX_FIX_PASSES=1
ENABLE_VISION_VERIFICATION=true
AGENTIC_MAX_TURNS=24

# Content-type routing / shadow checks
CONTENT_TYPE_PRIMARY_STRATEGY=rules
CONTENT_TYPE_SHADOW_ENABLED=true
CONTENT_TYPE_CONFIDENCE_THRESHOLD=0.55
SSE_HEARTBEAT_SECONDS=10.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_SSE_DEBUG=false

# Optional speaker audio
TTS_PROVIDER=minimax
TTS_API_KEY=
TTS_BASE_URL=https://api.minimaxi.com
TTS_MODEL=speech-2.8-hd
TTS_VOICE_ID=male-qn-qingse

# Optional live agent smoke test settings
AGENTLOOP_MODEL=
AGENTLOOP_API_BASE=
AGENTLOOP_API_KEY=
